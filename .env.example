# Supabase Local Credentials (erhältst du nach Ausführung von 'supabase start')
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key

# Stripe Credentials 
# (aus dem Stripe Dashboard -> Developers -> API Keys -> Secret key)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key

# (ausgeführt durch 'stripe listen', siehe README.md)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Cloudflare Turnstile (Newsletter-Captcha)
# Sitekey ist public, Secret gehört nur in die Supabase Function Env
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_your_site_key
TURNSTILE_SECRET_KEY=0x4AAAAAAA_your_secret_key
