---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Newsletter bestätigt | Klikkr"
  description="Dein Klikkr Newsletter-Abo ist bestätigt."
  lang="de"
  noindex={true}
>
  <div class="min-h-screen flex flex-col bg-zinc-950 text-zinc-50 selection:bg-emerald-500/30 font-sans">

    <header class="w-full py-4 px-4 md:px-6 border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <img
          src="/favicon.svg"
          alt="Klikkr Logo"
          class="h-7 w-7 object-contain"
        />
        <span class="font-bold text-xl tracking-tight text-zinc-50">
          Klikkr <span class="text-cyan-400">Pro</span>
        </span>
      </a>
      <a
        href="/"
        class="inline-flex h-9 items-center justify-center rounded-full bg-emerald-500 px-4 py-2 text-sm font-bold text-zinc-950 transition-transform hover:scale-105 hover:bg-emerald-600"
      >
        Zurück zur Webseite
      </a>
    </header>

    <main class="flex-1 flex flex-col items-center justify-center p-6 md:p-12 lg:p-24 text-center">
      <div class="max-w-2xl mx-auto space-y-8 animate-in fade-in zoom-in duration-700">

        <div class="w-24 h-24 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-8 border border-emerald-500/20 shadow-[0_0_30px_rgba(16,185,129,0.2)]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <div class="space-y-4">
          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
            Abo bestätigt!
          </h1>
          <p class="text-xl text-zinc-400 font-medium">
            Danke für deine Anmeldung. Du erhältst ab jetzt Neuigkeiten rund um
            Klikkr direkt in dein Postfach. Abmelden kannst du dich jederzeit
            über den Link am Ende jedes Newsletters.
          </p>
        </div>

        <a
          href="/"
          class="inline-flex h-12 items-center justify-center rounded-full bg-emerald-500 px-8 text-base font-bold text-zinc-950 transition-transform hover:scale-105 hover:bg-emerald-600"
        >
          Zur Startseite
        </a>

      </div>
    </main>

  </div>
</Layout>
