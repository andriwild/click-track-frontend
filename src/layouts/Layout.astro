---
import '../index.css';
import { getTranslations, getLocalizedPath, locales, localeLabels, type Locale } from '../i18n';
import { CartIcon } from '../components/CartIcon';
import { CartDrawer } from '../components/CartDrawer';

interface Props {
  title: string;
  currentPage?: string;
  lang?: Locale;
}

const { title, currentPage = 'home', lang = 'de' } = Astro.props;
const t = getTranslations(lang);

const tabs = [
  { id: 'home', label: t.nav.home, href: getLocalizedPath('/', lang) },
  { id: 'how-it-works', label: t.nav.howItWorks, href: getLocalizedPath('/how-it-works', lang) },
  { id: 'reviews', label: t.nav.reviews, href: getLocalizedPath('/reviews', lang) },
  { id: 'faq', label: t.nav.faq, href: getLocalizedPath('/faq', lang) },
];

const currentPathWithoutLang = Astro.url.pathname
  .replace(/^\/(en|fr|it)(\/|$)/, '/')
  .replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#09090b" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <meta name="description" content="Klikkr - The ultimate tactical, wearable score-tracking wristband for Padel, Tennis, and Squash." />
    
    <!-- Open Graph / Social Media Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://klikkr.ch" />
    <meta property="og:title" content="Klikkr | Wearable Score Tracker" />
    <meta property="og:description" content="Track every point seamlessly on your wrist without interrupting the game. The smart companion app for Padel, Tennis, and Squash." />
    <meta property="og:image" content="https://klikkr.ch/favicon.svg" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://klikkr.ch" />
    <meta name="twitter:title" content="Klikkr | Wearable Score Tracker" />
    <meta name="twitter:description" content="Track every point seamlessly on your wrist without interrupting the game. The smart companion app for Padel, Tennis, and Squash." />
    <meta name="twitter:image" content="https://klikkr.ch/favicon.svg" />

    <!-- Alternate language links for SEO -->
    {locales.map((loc) => (
      <link 
        rel="alternate" 
        hreflang={loc} 
        href={`https://klikkr.ch${getLocalizedPath(currentPathWithoutLang, loc)}`} 
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={`https://klikkr.ch${currentPathWithoutLang}`} />

    <!-- Favicons & App Icons -->
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <title>{title}</title>
    <script defer src="https://analytics.klikkr.ch/script.js" data-website-id="1bcb778e-5503-4a71-ab57-1d64d7bde4a6" data-domains="klikkr.ch"></script>
  </head>
  <body class="min-h-screen flex flex-col bg-zinc-950 text-zinc-50 selection:bg-emerald-500/30 font-sans">
    <header class="w-full border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50">
      <div class="flex items-center justify-between py-3 px-4 md:px-6">
        <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 flex-shrink-0">
          <img src="/logo_white.png" alt="Klikkr Logo" class="h-7 object-contain" />
        </a>

        <div class="flex items-center gap-2 flex-shrink-0">
          <!-- Language switcher -->
          <details class="relative" id="lang-switcher">
            <summary class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-semibold text-zinc-400 hover:text-zinc-200 bg-zinc-900/60 border border-zinc-800 transition-all cursor-pointer list-none [&::-webkit-details-marker]:hidden whitespace-nowrap">
              {localeLabels[lang]}
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="absolute left-0 top-full mt-1 py-1 flex flex-col bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl min-w-[120px] z-50">
              {locales.map((loc) => (
                <a
                  href={getLocalizedPath(currentPathWithoutLang, loc)}
                  class:list={[
                    'block px-4 py-2 text-sm font-semibold transition-colors whitespace-nowrap',
                    loc === lang
                      ? 'text-emerald-400 bg-emerald-400/10'
                      : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800',
                  ]}
                >
                  {localeLabels[loc]}
                </a>
              ))}
            </div>
          </details>

          <CartIcon client:load />

          <a
            href={getLocalizedPath('/', lang) + '#checkout'}
            class="hidden sm:inline-flex items-center justify-center rounded-full bg-emerald-500 hover:bg-emerald-600 text-zinc-950 font-bold transition-transform hover:scale-105 h-9 px-4 text-sm whitespace-nowrap"
          >
            {t.nav.orderNow}
          </a>
        </div>
      </div>

      <!-- Pill navigation – always visible -->
      <nav class="flex items-center justify-center gap-1 px-3 py-1.5 border-t border-zinc-900/60">
        <div class="flex items-center gap-1 bg-zinc-900/60 rounded-full p-1 border border-zinc-800">
          {tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={[
                'relative px-3 sm:px-4 py-1.5 rounded-full text-xs sm:text-sm font-semibold transition-all duration-300 whitespace-nowrap',
                currentPage === tab.id
                  ? 'bg-zinc-800 text-zinc-50 shadow-sm'
                  : 'text-zinc-400 hover:text-zinc-200',
              ]}
            >
              {tab.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <slot name="footer" />

    <CartDrawer client:load lang={lang} />

    <!-- Sticky mobile CTA -->
    <div id="sticky-cta" class="fixed bottom-0 inset-x-0 z-50 transition-transform duration-300" style="display:none; padding-bottom: env(safe-area-inset-bottom, 0px); background-color: #09090b;">
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/95 to-transparent pointer-events-none"></div>
      <div class="relative p-3">
        <a
          href={getLocalizedPath('/', lang) + '#checkout'}
          class="flex items-center justify-center w-full rounded-full bg-emerald-500 hover:bg-emerald-600 text-zinc-950 font-bold h-12 text-base shadow-[0_0_20px_rgba(16,185,129,0.3)] transition-all active:scale-95"
        >
          {t.nav.orderNow}
        </a>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('click', (e) => {
        const d = document.getElementById('lang-switcher');
        if (d && !d.contains(e.target)) d.removeAttribute('open');
      });

      // Track language switch
      document.querySelectorAll('#lang-switcher a').forEach(function(a) {
        a.addEventListener('click', function() {
          var lang = a.getAttribute('href').match(/^\/(en|fr|it)(\/|$)/);
          var target = lang ? lang[1] : 'de';
          if (window.umami) window.umami.track('language-switch', { language: target });
        });
      });

      // Track sticky CTA click
      var stickyCta = document.querySelector('#sticky-cta a');
      if (stickyCta) {
        stickyCta.addEventListener('click', function() {
          if (window.umami) window.umami.track('sticky-cta-order');
        });
      }

      // Track nav tab clicks
      document.querySelectorAll('nav a').forEach(function(a) {
        a.addEventListener('click', function() {
          if (window.umami) window.umami.track('nav-click', { page: a.textContent.trim() });
        });
      });

      // Track header "Order Now" button
      var headerCta = document.querySelector('header a[href*="#checkout"]');
      if (headerCta) {
        headerCta.addEventListener('click', function() {
          if (window.umami) window.umami.track('header-cta-order');
        });
      }

      (function() {
        var cta = document.getElementById('sticky-cta');
        if (!cta) return;
        var mq = window.matchMedia('(min-width: 640px)');
        function update() {
          var checkout = document.getElementById('checkout');
          var atCheckout = checkout && checkout.getBoundingClientRect().top < window.innerHeight;
          if (mq.matches || window.scrollY <= window.innerHeight || atCheckout) {
            cta.style.display = 'none';
          } else {
            cta.style.display = '';
          }
        }
        window.addEventListener('scroll', update, { passive: true });
        mq.addEventListener('change', update);
        update();
      })();
    </script>
  </body>
</html>
