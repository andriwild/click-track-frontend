---
import '../index.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <meta name="description" content="Klikkr Pro - The ultimate tactical, wearable score-tracking wristband for Padel, Tennis, and Squash." />
    
    <!-- Open Graph / Social Media Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://klikkr.ch" />
    <meta property="og:title" content="Klikkr Pro | Wearable Score Tracker" />
    <meta property="og:description" content="Track every point seamlessly on your wrist without interrupting the game. The smart companion app for Padel, Tennis, and Squash." />
    <!-- TODO: Replace with a real 1200x630px preview image URL deployed to your website -->
    <meta property="og:image" content="https://klikkr.ch/favicon.svg" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://klikkr.ch" />
    <meta name="twitter:title" content="Klikkr Pro | Wearable Score Tracker" />
    <meta name="twitter:description" content="Track every point seamlessly on your wrist without interrupting the game. The smart companion app for Padel, Tennis, and Squash." />
    <meta name="twitter:image" content="https://klikkr.ch/favicon.svg" />
    
    <!-- Web Analytics (Plausible - Privacy Friendly & Cookie-less) -->
    <!-- <script defer data-domain="klikkr.ch" src="https://plausible.io/js/script.js"></script> -->

    <!-- Favicons & App Icons (Google Search + Apple) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
