---
import '../index.css';
import {
  getTranslations,
  getLocalizedPath,
  getCanonicalUrl,
  locales,
  localeLabels,
  hreflangMap,
  pageAvailableLocales,
  SITE_URL,
  type Locale,
  type PageKey,
} from '../i18n';
import { CartIcon } from '../components/CartIcon';
import { CartDrawer } from '../components/CartDrawer';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pageKey?: PageKey;
  currentPage?: string;
  lang?: Locale;
  noindex?: boolean;
}

const {
  title: titleProp,
  description: descriptionProp,
  ogImage: ogImageProp,
  pageKey,
  currentPage = 'home',
  lang = 'de',
  noindex = false,
} = Astro.props;
const t = getTranslations(lang);

const seoForPage = pageKey ? t.seo[pageKey] : undefined;
const title = titleProp ?? seoForPage?.title ?? 'Klikkr';
const description = descriptionProp ?? seoForPage?.description ?? '';
const ogImagePath = ogImageProp ?? t.seo.defaultOgImage;
const ogImageUrl = ogImagePath.startsWith('http') ? ogImagePath : `${SITE_URL}${ogImagePath}`;

const tabs = [
  { id: 'home', label: t.nav.home, href: getLocalizedPath('/', lang) },
  { id: 'how-it-works', label: t.nav.howItWorks, href: getLocalizedPath('/how-it-works', lang) },
  { id: 'reviews', label: t.nav.reviews, href: getLocalizedPath('/reviews', lang) },
  { id: 'faq', label: t.nav.faq, href: getLocalizedPath('/faq', lang) },
];

const currentPathWithoutLang = Astro.url.pathname
  .replace(/^\/(en|fr|it)(\/|$)/, '/')
  .replace(/\/$/, '') || '/';

const canonicalUrl = getCanonicalUrl(currentPathWithoutLang, lang);

const alternateLocales = pageKey ? pageAvailableLocales[pageKey] : locales;
const xDefaultLocale: Locale = alternateLocales.includes('de') ? 'de' : alternateLocales[0];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Social Media Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={hreflangMap[lang].replace('-', '_')} />
    {alternateLocales.filter((loc) => loc !== lang).map((loc) => (
      <meta property="og:locale:alternate" content={hreflangMap[loc].replace('-', '_')} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Alternate language links for SEO -->
    {alternateLocales.map((loc) => (
      <link
        rel="alternate"
        hreflang={hreflangMap[loc]}
        href={getCanonicalUrl(currentPathWithoutLang, loc)}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={getCanonicalUrl(currentPathWithoutLang, xDefaultLocale)} />

    <!-- Favicons & App Icons -->
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Klikkr',
      url: SITE_URL,
      logo: `${SITE_URL}/logo.png`,
    })} />

    <slot name="head-extra" />

    <script defer src="https://analytics.klikkr.ch/script.js" data-website-id="1bcb778e-5503-4a71-ab57-1d64d7bde4a6" data-domains="klikkr.ch"></script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </head>
  <body class="min-h-screen flex flex-col bg-zinc-950 text-zinc-50 selection:bg-emerald-500/30 font-sans">
    <header class="w-full border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50">
      <div class="flex items-center justify-between gap-4 py-3 px-4 md:px-6">
        <!-- Logo + inline navigation, grouped on the left -->
        <div class="flex items-center gap-4 lg:gap-6 min-w-0">
          <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 flex-shrink-0">
            <img src="/logo_white.png" alt="Klikkr Logo" class="h-7 object-contain" />
          </a>

          <nav class="hidden lg:flex items-center">
            <div class="flex items-center gap-1 bg-zinc-900/60 rounded-full p-1 border border-zinc-800">
              {tabs.map((tab) => (
                <a
                  href={tab.href}
                  class:list={[
                    'relative px-4 py-1.5 rounded-full text-sm font-semibold transition-all duration-300 whitespace-nowrap',
                    currentPage === tab.id
                      ? 'bg-zinc-800 text-zinc-50 shadow-sm'
                      : 'text-zinc-400 hover:text-zinc-200',
                  ]}
                >
                  {tab.label}
                </a>
              ))}
            </div>
          </nav>
        </div>

        <div class="flex items-center gap-2 flex-shrink-0">
          <!-- App store badges: shown sm–md and xl+, hidden in the lg window where the inline nav needs the space -->
          <div class="hidden sm:flex lg:hidden xl:flex items-center gap-1.5">
            <a
              href="https://apps.apple.com/ch/app/klikkr/id6761069158"
              target="_blank"
              rel="noopener noreferrer"
              id="header-store-ios"
              aria-label={t.appFeatures.downloadAppStore}
              title={t.appFeatures.downloadAppStore}
              class="flex items-center justify-center h-9 w-9 rounded-full text-zinc-300 hover:text-zinc-50 bg-zinc-900/60 border border-zinc-800 transition-all hover:scale-105"
            >
              <svg class="w-[18px] h-[18px]" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
                <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
              </svg>
            </a>
            <a
              href="https://play.google.com/store/apps/details?id=ch.wild.klikkr"
              target="_blank"
              rel="noopener noreferrer"
              id="header-store-android"
              aria-label={t.appFeatures.downloadGooglePlay}
              title={t.appFeatures.downloadGooglePlay}
              class="flex items-center justify-center h-9 w-9 rounded-full text-zinc-300 hover:text-zinc-50 bg-zinc-900/60 border border-zinc-800 transition-all hover:scale-105"
            >
              <svg class="w-[18px] h-[18px]" viewBox="0 0 512 512" aria-hidden="true">
                <path fill="#00d4ff" d="M48 59.49v393a4.33 4.33 0 0 0 7.37 3.07L260 256 55.37 56.42A4.33 4.33 0 0 0 48 59.49z"/>
                <path fill="#00f076" d="M345.8 174 89.22 32.64l-.16-.09c-4.42-2.43-8.62 3.53-5 7.06l201.13 195.36z"/>
                <path fill="#ffd400" d="M84.08 472.39c-3.64 3.53.56 9.49 5 7.06l.16-.09L345.8 338l-60.61-60.93z"/>
                <path fill="#f63449" d="M449.38 231.6 374.55 191l-67.13 65 67.12 65 74.84-40.59a28 28 0 0 0 0-48.81z"/>
              </svg>
            </a>
          </div>

          <!-- Language switcher -->
          <details class="relative" id="lang-switcher">
            <summary class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-semibold text-zinc-400 hover:text-zinc-200 bg-zinc-900/60 border border-zinc-800 transition-all cursor-pointer list-none [&::-webkit-details-marker]:hidden whitespace-nowrap">
              {localeLabels[lang]}
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="absolute left-0 top-full mt-1 py-1 flex flex-col bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl min-w-[120px] z-50">
              {locales.map((loc) => (
                <a
                  href={getLocalizedPath(currentPathWithoutLang, loc)}
                  class:list={[
                    'block px-4 py-2 text-sm font-semibold transition-colors whitespace-nowrap',
                    loc === lang
                      ? 'text-emerald-400 bg-emerald-400/10'
                      : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800',
                  ]}
                >
                  {localeLabels[loc]}
                </a>
              ))}
            </div>
          </details>

          <CartIcon client:load />

          <a
            href={getLocalizedPath('/', lang) + '#checkout'}
            class="hidden sm:inline-flex items-center justify-center rounded-full bg-emerald-500 hover:bg-emerald-600 text-zinc-950 font-bold transition-transform hover:scale-105 h-9 px-4 text-sm whitespace-nowrap"
          >
            {t.nav.orderNow}
          </a>
        </div>
      </div>

      <!-- Pill navigation – second row below lg (wider screens use the inline nav next to the logo) -->
      <nav class="lg:hidden flex items-center justify-center gap-1 px-3 py-1.5 border-t border-zinc-900/60">
        <div class="flex items-center gap-1 bg-zinc-900/60 rounded-full p-1 border border-zinc-800">
          {tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={[
                'relative px-3 sm:px-4 py-1.5 rounded-full text-xs sm:text-sm font-semibold transition-all duration-300 whitespace-nowrap',
                currentPage === tab.id
                  ? 'bg-zinc-800 text-zinc-50 shadow-sm'
                  : 'text-zinc-400 hover:text-zinc-200',
              ]}
            >
              {tab.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <slot name="footer" />

    <CartDrawer client:load lang={lang} />

    <script is:inline>
      document.addEventListener('click', (e) => {
        const d = document.getElementById('lang-switcher');
        if (d && !d.contains(e.target)) d.removeAttribute('open');
      });

      // Track language switch
      document.querySelectorAll('#lang-switcher a').forEach(function(a) {
        a.addEventListener('click', function() {
          var lang = a.getAttribute('href').match(/^\/(en|fr|it)(\/|$)/);
          var target = lang ? lang[1] : 'de';
          if (window.umami) window.umami.track('language-switch', { language: target });
        });
      });

      // Track header app store badge clicks
      var iosBadge = document.getElementById('header-store-ios');
      if (iosBadge) iosBadge.addEventListener('click', function() {
        if (window.umami) window.umami.track('header-store-ios');
      });
      var androidBadge = document.getElementById('header-store-android');
      if (androidBadge) androidBadge.addEventListener('click', function() {
        if (window.umami) window.umami.track('header-store-android');
      });

      // Track nav tab clicks
      document.querySelectorAll('nav a').forEach(function(a) {
        a.addEventListener('click', function() {
          if (window.umami) window.umami.track('nav-click', { page: a.textContent.trim() });
        });
      });

      // Track header "Order Now" button
      var headerCta = document.querySelector('header a[href*="#checkout"]');
      if (headerCta) {
        headerCta.addEventListener('click', function() {
          if (window.umami) window.umami.track('header-cta-order');
        });
      }

    </script>
  </body>
</html>
