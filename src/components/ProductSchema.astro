---
import { getTranslations, getCanonicalUrl, SITE_URL, type Locale } from '../i18n';
import { products } from '../config/products';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const offerUrl = getCanonicalUrl('/', lang);

type ProductKey = keyof typeof t.products;

const productSchemas = products.map((p) => {
  const info = t.products[p.slug as ProductKey] as { name: string; description: string } | undefined;
  return {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: info?.name ?? p.slug,
    description: info?.description ?? '',
    image: `${SITE_URL}${p.image}`,
    sku: p.slug,
    brand: { '@type': 'Brand', name: 'Klikkr' },
    offers: {
      '@type': 'Offer',
      price: (p.priceCHF / 100).toFixed(2),
      priceCurrency: 'CHF',
      availability: 'https://schema.org/PreOrder',
      url: offerUrl,
    },
  };
});
---

{productSchemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
